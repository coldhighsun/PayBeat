<helpers:AutoSizingWindow
    x:Class="PayBeat.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:PayBeat.WinUI.Views"
    xmlns:helpers="using:PayBeat.WinUI.Helpers">

    <Grid x:Name="RootGrid" MinHeight="32"
          Background="Transparent"
          RenderTransformOrigin="0.5,0.5"
          PointerEntered="RootGrid_PointerEntered"
          PointerExited="RootGrid_PointerExited">

        <Grid.RenderTransform>
            <ScaleTransform x:Name="AttentionScaleTransform" />
        </Grid.RenderTransform>

        <Grid.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutSubItem Text="{x:Bind DisplayModeLabel, Mode=OneWay}">
                    <ToggleMenuFlyoutItem Text="{x:Bind FlexLabel, Mode=OneWay}"
                                          IsChecked="{x:Bind ViewModel.IsFlexMode, Mode=OneWay}"
                                          Click="FlexMenuItem_Click" />
                    <ToggleMenuFlyoutItem Text="{x:Bind NormalLabel, Mode=OneWay}"
                                          IsChecked="{x:Bind ViewModel.IsNormalMode, Mode=OneWay}"
                                          Click="NormalMenuItem_Click" />
                    <ToggleMenuFlyoutItem Text="{x:Bind MiniLabel, Mode=OneWay}"
                                          IsChecked="{x:Bind ViewModel.IsMiniMode, Mode=OneWay}"
                                          Click="MiniMenuItem_Click" />
                    <ToggleMenuFlyoutItem Text="{x:Bind NoneLabel, Mode=OneWay}"
                                          IsChecked="{x:Bind ViewModel.IsNoneMode, Mode=OneWay}"
                                          Click="NoneMenuItem_Click" />
                </MenuFlyoutSubItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="{x:Bind SettingsLabel, Mode=OneWay}" Command="{x:Bind ViewModel.OpenSettingsCommand}" />
                <MenuFlyoutItem Text="{x:Bind AboutLabel, Mode=OneWay}" Command="{x:Bind ViewModel.OpenAboutCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="{x:Bind ExitLabel, Mode=OneWay}" Command="{x:Bind ViewModel.ExitCommand}" />
            </MenuFlyout>
        </Grid.ContextFlyout>

        <views:NormalView x:Name="NormalContent" DoubleTapped="Content_DoubleTapped" Background="Transparent" />
        <views:MiniView x:Name="MiniContent" Visibility="Collapsed" DoubleTapped="Content_DoubleTapped" />
        <views:FlexView x:Name="FlexContent" Visibility="Collapsed" DoubleTapped="Content_DoubleTapped" />
    </Grid>
</helpers:AutoSizingWindow>
