<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Color palette: Catppuccin Mocha - ported unchanged from the WPF build's Styles.xaml.
    -->
    <Color x:Key="BaseColor">#1E1E2E</Color>
    <Color x:Key="SurfaceColor">#313244</Color>
    <Color x:Key="OverlayColor">#45475A</Color>
    <Color x:Key="TextColor">#CDD6F4</Color>
    <Color x:Key="SubtextColor">#9399B2</Color>
    <Color x:Key="MutedColor">#6C7086</Color>
    <Color x:Key="GreenColor">#A6E3A1</Color>
    <Color x:Key="BlueColor">#89B4FA</Color>
    <Color x:Key="RedColor">#F38BA8</Color>

    <SolidColorBrush x:Key="BaseBrush" Color="{StaticResource BaseColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="OverlayBrush" Color="{StaticResource OverlayColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="SubtextBrush" Color="{StaticResource SubtextColor}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}" />
    <SolidColorBrush x:Key="BlueBrush" Color="{StaticResource BlueColor}" />
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}" />

    <!--
        Flat Button - full ControlTemplate rewrite. WinUI3 has no Trigger/ControlTemplate.Triggers;
        the equivalent is VisualStateManager targeting the standard "CommonStates" group that
        Button's default logic drives (Normal/PointerOver/Pressed/Disabled).
    -->
    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootBorder.Opacity" Value="0.82" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootBorder.Opacity" Value="0.65" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="RootBorder.Opacity" Value="0.4" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Foreground="{TemplateBinding Foreground}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        TextBox/ComboBox/ProgressBar are recolored via theme resource key overrides rather than
        full ControlTemplate rewrites. WinUI3's built-in templates for these controls have many
        required named parts (placeholder/header presenters, drop-down glyph states, popup border,
        etc.); reimplementing them from scratch is high-risk to get subtly wrong with no real
        content yet to validate against (Settings UI lands in Stage 6). Overriding the documented
        brush resource keys is WinUI3's supported low-risk recoloring path and leaves the system
        template's behavior (focus, placeholder, drop-down popup) intact.
    -->

    <!-- TextBox -->
    <SolidColorBrush x:Key="TextControlBackground" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="TextControlForeground" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource OverlayColor}" />
    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="{StaticResource BlueColor}" />
    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="{StaticResource BlueColor}" />
    <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="{StaticResource BlueColor}" />
    <Thickness x:Key="TextControlBorderThemeThickness">1</Thickness>
    <CornerRadius x:Key="TextControlCornerRadius">6</CornerRadius>

    <!-- ComboBox -->
    <SolidColorBrush x:Key="ComboBoxBackground" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="ComboBoxBackgroundDisabled" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="ComboBoxForeground" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="ComboBoxForegroundDisabled" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="{StaticResource OverlayColor}" />
    <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="{StaticResource BlueColor}" />
    <SolidColorBrush x:Key="ComboBoxBorderBrushPressed" Color="{StaticResource BlueColor}" />
    <SolidColorBrush x:Key="ComboBoxDropDownGlyphForeground" Color="{StaticResource SubtextColor}" />
    <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="ComboBoxDropDownBackgroundPointerOver" Color="{StaticResource OverlayColor}" />
    <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="{StaticResource OverlayColor}" />
    <SolidColorBrush x:Key="ComboBoxItemBackground" Color="Transparent" />
    <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="{StaticResource OverlayColor}" />
    <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="{StaticResource OverlayColor}" />
    <SolidColorBrush x:Key="ComboBoxItemForeground" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="{StaticResource BlueColor}" />
    <CornerRadius x:Key="ComboBoxCornerRadius">6</CornerRadius>

    <!--
        ProgressBar - unlike WPF, WinUI3's default template already exposes flat Background/
        Foreground/CornerRadius as direct properties, so a Style with Setters is enough; no
        ControlTemplate override needed.
    -->
    <Style TargetType="ProgressBar">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource BlueBrush}" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Height" Value="5" />
    </Style>

    <!-- ToggleSwitch - recolored via theme resource key overrides, same low-risk approach as TextBox/ComboBox above. -->
    <SolidColorBrush x:Key="ToggleSwitchFillOff" Color="{StaticResource OverlayColor}" />
    <SolidColorBrush x:Key="ToggleSwitchFillOffPointerOver" Color="{StaticResource OverlayColor}" />
    <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="{StaticResource BlueColor}" />
    <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="{StaticResource BlueColor}" />
    <SolidColorBrush x:Key="ToggleSwitchStrokeOff" Color="{StaticResource OverlayColor}" />
    <SolidColorBrush x:Key="ToggleSwitchStrokeOffPointerOver" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="ToggleSwitchStrokeOn" Color="{StaticResource BlueColor}" />
    <SolidColorBrush x:Key="ToggleSwitchStrokeOnPointerOver" Color="{StaticResource BlueColor}" />
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOff" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOffPointerOver" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOn" Color="{StaticResource BaseColor}" />
    <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPointerOver" Color="{StaticResource BaseColor}" />
    <SolidColorBrush x:Key="ToggleSwitchContentForeground" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="ToggleSwitchHeaderForeground" Color="{StaticResource SubtextColor}" />

    <!-- Settings window: card border wrapping each settings section, and its title label. -->
    <Style x:Key="SettingsCardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="SettingsSectionTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BlueBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="20" />
    </Style>

    <Style x:Key="SettingsFieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource SubtextBrush}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="SettingsDivider" TargetType="Rectangle">
        <Setter Property="Fill" Value="{StaticResource OverlayBrush}" />
        <Setter Property="Height" Value="1" />
    </Style>

</ResourceDictionary>
