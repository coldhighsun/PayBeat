<helpers:AutoSizingWindow
    x:Class="PayBeat.WinUI.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:PayBeat.WinUI.Helpers">

    <Grid x:Name="RootGrid"
          Background="{StaticResource BaseBrush}"
          Width="440">

        <Border BorderBrush="{StaticResource OverlayBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid x:Name="TitleBar" Grid.Row="0" Background="Transparent">
                    <TextBlock Text="{x:Bind TitleLabel, Mode=OneWay}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="24,20,24,12" />
                </Grid>

                <ScrollViewer Grid.Row="1"
                              Padding="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Disabled">
                    <StackPanel Spacing="12" Margin="24,0,20,12">

                        <!-- Salary card -->
                        <Border Style="{StaticResource SettingsCardBorder}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{x:Bind SalarySectionLabel, Mode=OneWay}" Style="{StaticResource SettingsSectionTitle}" />

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="{x:Bind DailySalaryLabel, Mode=OneWay}" Style="{StaticResource SettingsFieldLabel}" />
                                        <TextBox Text="{Binding DailySalaryText, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="¥/$" Style="{StaticResource SettingsFieldLabel}" />
                                        <TextBox Text="{Binding CurrencyText, Mode=TwoWay}" MaxLength="3" MinWidth="0" HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </Grid>

                                <Rectangle Style="{StaticResource SettingsDivider}" />

                                <TextBlock Text="{x:Bind ScheduleSectionLabel, Mode=OneWay}" Style="{StaticResource SettingsSectionTitle}" />

                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind WorkStartLabel, Mode=OneWay}" Style="{StaticResource SettingsFieldLabel}" />
                                    <TimePicker x:Name="WorkStartPicker" TimeChanged="WorkStartPicker_TimeChanged" HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind WorkEndLabel, Mode=OneWay}" Style="{StaticResource SettingsFieldLabel}" />
                                    <TimePicker x:Name="WorkEndPicker" TimeChanged="WorkEndPicker_TimeChanged" HorizontalAlignment="Stretch" />
                                </StackPanel>

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind LunchBreakEnabledLabel, Mode=OneWay}" Foreground="{StaticResource TextBrush}" FontSize="13" VerticalAlignment="Center" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding LunchBreakEnabled, Mode=TwoWay}" OnContent="" OffContent="" />
                                </Grid>
                                <StackPanel Spacing="12" Visibility="{Binding LunchBreakEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Bind LunchBreakStartLabel, Mode=OneWay}" Style="{StaticResource SettingsFieldLabel}" />
                                        <TimePicker x:Name="LunchStartPicker" TimeChanged="LunchStartPicker_TimeChanged" HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Bind LunchBreakEndLabel, Mode=OneWay}" Style="{StaticResource SettingsFieldLabel}" />
                                        <TimePicker x:Name="LunchEndPicker" TimeChanged="LunchEndPicker_TimeChanged" HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </StackPanel>

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind WorkOnWeekendsLabel, Mode=OneWay}" Foreground="{StaticResource TextBrush}" FontSize="13" VerticalAlignment="Center" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding WorkOnWeekends, Mode=TwoWay}" OnContent="" OffContent="" />
                                </Grid>

                                <Rectangle Style="{StaticResource SettingsDivider}" />

                                <TextBlock Text="{x:Bind RefreshSectionLabel, Mode=OneWay}" Style="{StaticResource SettingsSectionTitle}" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind RefreshIntervalLabel, Mode=OneWay}" Style="{StaticResource SettingsFieldLabel}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding RefreshInterval}" Foreground="{StaticResource GreenBrush}" FontSize="12" VerticalAlignment="Center" />
                                </Grid>
                                <Slider Minimum="1" Maximum="60" Value="{Binding RefreshInterval, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>

                        <!-- Notifications card -->
                        <Border Style="{StaticResource SettingsCardBorder}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{x:Bind NotificationsSectionLabel, Mode=OneWay}" Style="{StaticResource SettingsSectionTitle}" />

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind EndOfDayReminderLabel, Mode=OneWay}" Foreground="{StaticResource TextBrush}" FontSize="13" VerticalAlignment="Center" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding EnableEndOfDayReminder, Mode=TwoWay}" OnContent="" OffContent="" />
                                </Grid>
                                <StackPanel Spacing="4" Visibility="{Binding EnableEndOfDayReminder, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind EndOfDayReminderMinutesLabel, Mode=OneWay}" Style="{StaticResource SettingsFieldLabel}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding EndOfDayReminderMinutesText}" Foreground="{StaticResource GreenBrush}" FontSize="12" VerticalAlignment="Center" />
                                    </Grid>
                                    <Slider Minimum="0" Maximum="60" Value="{Binding EndOfDayReminderMinutesText, Mode=TwoWay, Converter={StaticResource StringToDoubleConverter}}" />
                                </StackPanel>

                                <Rectangle Style="{StaticResource SettingsDivider}" />

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind MilestoneNotificationsLabel, Mode=OneWay}" Foreground="{StaticResource TextBrush}" FontSize="13" VerticalAlignment="Center" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding EnableMilestoneNotifications, Mode=TwoWay}" OnContent="" OffContent="" />
                                </Grid>
                                <StackPanel Spacing="4" Visibility="{Binding EnableMilestoneNotifications, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind MilestoneAmountLabel, Mode=OneWay}" Style="{StaticResource SettingsFieldLabel}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding MilestoneAmountText}" Foreground="{StaticResource GreenBrush}" FontSize="12" VerticalAlignment="Center" />
                                    </Grid>
                                    <Slider Minimum="100" Maximum="1000" Value="{Binding MilestoneAmountText, Mode=TwoWay, Converter={StaticResource StringToDoubleConverter}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Display card -->
                        <Border Style="{StaticResource SettingsCardBorder}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{x:Bind DisplaySectionLabel, Mode=OneWay}" Style="{StaticResource SettingsSectionTitle}" />

                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind DisplayModeLabel, Mode=OneWay}" Style="{StaticResource SettingsFieldLabel}" />
                                    <Grid ColumnSpacing="8" RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <RadioButton Grid.Row="0" Grid.Column="0" Content="{x:Bind NormalLabel, Mode=OneWay}" IsChecked="{Binding IsNormalMode, Mode=TwoWay}" GroupName="DisplayMode" />
                                        <RadioButton Grid.Row="0" Grid.Column="1" Content="{x:Bind MiniLabel, Mode=OneWay}" IsChecked="{Binding IsMiniMode, Mode=TwoWay}" GroupName="DisplayMode" />
                                        <RadioButton Grid.Row="1" Grid.Column="0" Content="{x:Bind FlexLabel, Mode=OneWay}" IsChecked="{Binding IsFlexMode, Mode=TwoWay}" GroupName="DisplayMode" />
                                        <RadioButton Grid.Row="1" Grid.Column="1" Content="{x:Bind NoneLabel, Mode=OneWay}" IsChecked="{Binding IsNoneMode, Mode=TwoWay}" GroupName="DisplayMode" />
                                    </Grid>
                                </StackPanel>

                                <Rectangle Style="{StaticResource SettingsDivider}" />

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind OpacityLabel, Mode=OneWay}" Style="{StaticResource SettingsFieldLabel}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Opacity}" Foreground="{StaticResource GreenBrush}" FontSize="12" VerticalAlignment="Center" />
                                </Grid>
                                <Slider Minimum="0.1" Maximum="1.0" StepFrequency="0.05" Value="{Binding Opacity, Mode=TwoWay}" />

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind AlwaysOnTopLabel, Mode=OneWay}" Foreground="{StaticResource TextBrush}" FontSize="13" VerticalAlignment="Center" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding AlwaysOnTop, Mode=TwoWay}" OnContent="" OffContent="" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- System card -->
                        <Border Style="{StaticResource SettingsCardBorder}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{x:Bind SystemSectionLabel, Mode=OneWay}" Style="{StaticResource SettingsSectionTitle}" />

                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind RunAtStartupLabel, Mode=OneWay}" Foreground="{StaticResource TextBrush}" FontSize="13" VerticalAlignment="Center" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding RunAtStartup, Mode=TwoWay}" OnContent="" OffContent="" />
                                </Grid>

                                <Rectangle Style="{StaticResource SettingsDivider}" />

                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind LanguageLabel, Mode=OneWay}" Style="{StaticResource SettingsFieldLabel}" />
                                    <ComboBox x:Name="LanguageCombo"
                                              ItemsSource="{Binding AvailableLanguages}"
                                              DisplayMemberPath="Name"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="LanguageCombo_SelectionChanged" />
                                </StackPanel>

                                <Rectangle Style="{StaticResource SettingsDivider}" />

                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind HotkeyLabel, Mode=OneWay}" Style="{StaticResource SettingsFieldLabel}" />
                                    <TextBlock Text="{Binding HotkeyDisplayText}" Foreground="{StaticResource TextBrush}" FontSize="13" />
                                    <TextBlock Text="{x:Bind HotkeyHintLabel, Mode=OneWay}" Foreground="{StaticResource MutedBrush}" FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="24,0,24,20" Spacing="8">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource RedBrush}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                        <Button Content="{x:Bind CancelLabel, Mode=OneWay}" Command="{Binding CancelCommand}" />
                        <Button Content="{x:Bind SaveLabel, Mode=OneWay}" Command="{Binding SaveCommand}" Background="{StaticResource BlueBrush}" Foreground="{StaticResource BaseBrush}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</helpers:AutoSizingWindow>