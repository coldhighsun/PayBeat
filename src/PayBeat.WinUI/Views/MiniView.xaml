<UserControl
    x:Class="PayBeat.WinUI.Views.MiniView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <Border x:Name="BackgroundBorder"
                Background="{StaticResource BaseBrush}"
                BorderBrush="{StaticResource OverlayBrush}"
                BorderThickness="1" />

        <StackPanel>
            <TextBlock Text="{Binding EarnedFormatted}"
                       Foreground="{StaticResource GreenBrush}"
                       FontSize="15"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="12,5,12,4" />

            <ProgressBar Value="{Binding Progress, Mode=OneWay}"
                         Minimum="0"
                         Maximum="1"
                         Height="3" />
        </StackPanel>
    </Grid>
</UserControl>
