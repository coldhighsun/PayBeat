<UserControl
    x:Class="PayBeat.WinUI.Views.FlexView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1E1E2E" Offset="0" />
                <GradientStop Color="#181825" Offset="0.5" />
                <GradientStop Color="#1E1E2E" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <!--
            Glow behind the amount. WinUI3's UIElement has no Effect property (WPF's
            BlurEffect/DropShadowEffect don't exist), so this is a flat low-opacity fill instead
            of a blurred glow - a decorative approximation, not a functional gap.
        -->
        <Ellipse Width="900" Height="500"
                 Fill="{StaticResource GreenBrush}"
                 Opacity="0.04" />

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- Header -->
            <TextBlock Text="PayBeat"
                       Foreground="{StaticResource SubtextBrush}"
                       FontSize="22"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center" />

            <!-- Huge earned amount -->
            <TextBlock x:Name="AmountText"
                       Text="{Binding EarnedFormatted}"
                       Foreground="{StaticResource GreenBrush}"
                       FontSize="160"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <ScaleTransform x:Name="AmountScale" />
                </TextBlock.RenderTransform>
            </TextBlock>

            <!-- Progress bar + percentage -->
            <ProgressBar Value="{Binding Progress, Mode=OneWay}"
                         Minimum="0" Maximum="1"
                         Width="700"
                         Height="14"
                         Margin="0,24,0,8" />
            <TextBlock Text="{Binding ProgressFormatted, Mode=OneWay}"
                       Foreground="{StaticResource SubtextBrush}"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,32" />

            <!-- Stats row -->
            <Grid Width="700">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{x:Bind ElapsedLabel, Mode=OneWay}"
                               Foreground="{StaticResource MutedBrush}" FontSize="13" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding ElapsedFormatted, Mode=OneWay}"
                               Foreground="{StaticResource TextBrush}" FontSize="26" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="{x:Bind RemainingLabel, Mode=OneWay}"
                               Foreground="{StaticResource MutedBrush}" FontSize="13" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding RemainingFormatted, Mode=OneWay}"
                               Foreground="{StaticResource TextBrush}" FontSize="26" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="{x:Bind DailySalaryLabel, Mode=OneWay}"
                               Foreground="{StaticResource MutedBrush}" FontSize="13" HorizontalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <TextBlock Text="{Binding Currency}"
                                   Foreground="{StaticResource TextBrush}" FontSize="26" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding DailySalaryFormatted}"
                                   Foreground="{StaticResource TextBrush}" FontSize="26" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="{x:Bind WorkWindowLabel, Mode=OneWay}"
                               Foreground="{StaticResource MutedBrush}" FontSize="13" HorizontalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <TextBlock Text="{Binding WorkStartFormatted}"
                                   Foreground="{StaticResource TextBrush}" FontSize="26" FontWeight="SemiBold" />
                        <TextBlock Text="–"
                                   Foreground="{StaticResource TextBrush}" FontSize="26" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding WorkEndFormatted}"
                                   Foreground="{StaticResource TextBrush}" FontSize="26" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>
            </Grid>

        </StackPanel>
    </Grid>
</UserControl>
