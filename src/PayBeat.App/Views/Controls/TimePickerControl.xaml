<UserControl x:Class="PayBeat.App.Views.Controls.TimePickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#313244" BorderBrush="#45475A" BorderThickness="1" CornerRadius="5">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="4,2">

            <!-- Hour -->
            <StackPanel>
                <Button x:Name="HourUp" Content="▲" Click="HourUp_Click"
                        Width="24" Height="14" Padding="0"
                        Background="Transparent" Foreground="#9399B2" FontSize="7"/>
                <TextBox x:Name="HourBox"
                         Width="24" Height="22"
                         TextAlignment="Center"
                         VerticalContentAlignment="Center"
                         Background="Transparent" Foreground="#CDD6F4"
                         BorderThickness="0" FontSize="13" FontWeight="SemiBold"
                         MaxLength="2"
                         PreviewTextInput="NumericOnly_PreviewTextInput"
                         PreviewKeyDown="Hour_PreviewKeyDown"
                         GotFocus="TextBox_GotFocus"
                         LostFocus="HourBox_LostFocus"/>
                <Button x:Name="HourDown" Content="▼" Click="HourDown_Click"
                        Width="24" Height="14" Padding="0"
                        Background="Transparent" Foreground="#9399B2" FontSize="7"/>
            </StackPanel>

            <TextBlock Text=":" Foreground="#CDD6F4" FontSize="14" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="1,0"/>

            <!-- Minute -->
            <StackPanel>
                <Button x:Name="MinuteUp" Content="▲" Click="MinuteUp_Click"
                        Width="24" Height="14" Padding="0"
                        Background="Transparent" Foreground="#9399B2" FontSize="7"/>
                <TextBox x:Name="MinuteBox"
                         Width="24" Height="22"
                         TextAlignment="Center"
                         VerticalContentAlignment="Center"
                         Background="Transparent" Foreground="#CDD6F4"
                         BorderThickness="0" FontSize="13" FontWeight="SemiBold"
                         MaxLength="2"
                         PreviewTextInput="NumericOnly_PreviewTextInput"
                         PreviewKeyDown="Minute_PreviewKeyDown"
                         GotFocus="TextBox_GotFocus"
                         LostFocus="MinuteBox_LostFocus"/>
                <Button x:Name="MinuteDown" Content="▼" Click="MinuteDown_Click"
                        Width="24" Height="14" Padding="0"
                        Background="Transparent" Foreground="#9399B2" FontSize="7"/>
            </StackPanel>

        </StackPanel>
    </Border>
</UserControl>
