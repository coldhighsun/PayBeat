<UserControl x:Class="PayBeat.App.Views.FlexView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid">
        <Grid.Background>
            <LinearGradientBrush x:Name="BackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="BackgroundStopStart" Color="{DynamicResource BaseColor}" Offset="0"/>
                <GradientStop x:Name="BackgroundStopMiddle" Color="{DynamicResource FlexGradientMidColor}" Offset="0.5"/>
                <GradientStop x:Name="BackgroundStopEnd" Color="{DynamicResource BaseColor}" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Glow behind the amount -->
        <Ellipse x:Name="GlowEllipse"
                 Width="900" Height="500"
                 Fill="{DynamicResource GreenBrush}"
                 Opacity="0.08">
            <Ellipse.Effect>
                <BlurEffect Radius="140"/>
            </Ellipse.Effect>
        </Ellipse>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- Header -->
            <TextBlock Text="PayBeat"
                       Foreground="{DynamicResource SubtextBrush}"
                       FontFamily="Segoe UI"
                       FontSize="22"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>

            <!-- Huge earned amount -->
            <TextBlock x:Name="AmountText"
                       Text="{Binding EarnedFormatted}"
                       Foreground="{DynamicResource GreenBrush}"
                       FontFamily="Segoe UI"
                       FontSize="160"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <ScaleTransform x:Name="AmountScale"/>
                </TextBlock.RenderTransform>
                <TextBlock.Effect>
                    <DropShadowEffect Color="{DynamicResource GreenColor}" Opacity="0.55" BlurRadius="40" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Progress bar + percentage -->
            <ProgressBar Value="{Binding Progress, Mode=OneWay}"
                         Minimum="0" Maximum="1"
                         Width="700"
                         Height="14"
                         Margin="0,24,0,8"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource BlueBrush}"
                         BorderThickness="0"/>
            <TextBlock Text="{Binding Progress, Mode=OneWay, StringFormat=P2}"
                       Foreground="{DynamicResource SubtextBrush}"
                       FontFamily="Segoe UI"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,32"/>

            <!-- Stats row -->
            <Grid Width="700">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource View.Elapsed}"
                               Foreground="{DynamicResource MutedBrush}" FontFamily="Segoe UI" FontSize="13" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ElapsedFormatted, Mode=OneWay}"
                               Foreground="{DynamicResource TextBrush}" FontFamily="Segoe UI" FontSize="26" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="{DynamicResource View.Remaining}"
                               Foreground="{DynamicResource MutedBrush}" FontFamily="Segoe UI" FontSize="13" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding RemainingFormatted, Mode=OneWay}"
                               Foreground="{DynamicResource TextBrush}" FontFamily="Segoe UI" FontSize="26" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="{DynamicResource View.DailySalary}"
                               Foreground="{DynamicResource MutedBrush}" FontFamily="Segoe UI" FontSize="13" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <TextBlock Text="{Binding Currency, Mode=OneWay}"
                                   Foreground="{DynamicResource TextBrush}" FontFamily="Segoe UI" FontSize="26" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding DailySalary, StringFormat=N2, Mode=OneWay}"
                                   Foreground="{DynamicResource TextBrush}" FontFamily="Segoe UI" FontSize="26" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="{DynamicResource View.WorkWindow}"
                               Foreground="{DynamicResource MutedBrush}" FontFamily="Segoe UI" FontSize="13" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <TextBlock Text="{Binding WorkStart, StringFormat=HH:mm, Mode=OneWay}"
                                   Foreground="{DynamicResource TextBrush}" FontFamily="Segoe UI" FontSize="26" FontWeight="SemiBold"/>
                        <TextBlock Text="–"
                                   Foreground="{DynamicResource TextBrush}" FontFamily="Segoe UI" FontSize="26" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding WorkEnd, StringFormat=HH:mm, Mode=OneWay}"
                                   Foreground="{DynamicResource TextBrush}" FontFamily="Segoe UI" FontSize="26" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

        </StackPanel>
    </Grid>
</UserControl>
