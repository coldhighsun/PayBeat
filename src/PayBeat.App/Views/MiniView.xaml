<UserControl x:Class="PayBeat.App.Views.MiniView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{DynamicResource BaseBrush}"
            CornerRadius="8"
            BorderBrush="{DynamicResource OverlayBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.4" BlurRadius="16" ShadowDepth="0"/>
        </Border.Effect>

        <StackPanel>
            <TextBlock Text="{Binding EarnedFormatted}"
                       Foreground="{DynamicResource GreenBrush}"
                       FontFamily="Segoe UI"
                       FontSize="15"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="12,7,12,6"/>

            <ProgressBar Value="{Binding Progress, Mode=OneWay}"
                         Minimum="0"
                         Maximum="1"
                         Height="3"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource BlueBrush}"
                         BorderThickness="0"/>
        </StackPanel>
    </Border>
</UserControl>
