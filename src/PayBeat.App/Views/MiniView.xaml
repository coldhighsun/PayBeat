<UserControl x:Class="PayBeat.App.Views.MiniView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#1E1E2E"
            CornerRadius="8"
            BorderBrush="#45475A"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.4" BlurRadius="16" ShadowDepth="0"/>
        </Border.Effect>

        <StackPanel>
            <TextBlock Text="{Binding EarnedFormatted}"
                       Foreground="#A6E3A1"
                       FontFamily="Segoe UI"
                       FontSize="15"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="12,7,12,6"/>

            <ProgressBar Value="{Binding Progress, Mode=OneWay}"
                         Minimum="0"
                         Maximum="1"
                         Height="3"
                         Background="#313244"
                         Foreground="#89B4FA"
                         BorderThickness="0"/>
        </StackPanel>
    </Border>
</UserControl>
