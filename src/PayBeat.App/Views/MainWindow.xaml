<Window x:Class="PayBeat.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:views="clr-namespace:PayBeat.App.Views"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Topmost="{Binding AlwaysOnTop}"
        RenderTransformOrigin="0.5,0.5">

    <Window.RenderTransform>
        <ScaleTransform/>
    </Window.RenderTransform>

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="{DynamicResource Menu.DisplayMode}">
                <MenuItem Header="{DynamicResource Menu.Normal}"
                          IsCheckable="True"
                          IsChecked="{Binding IsNormalMode, Mode=OneWay}"
                          Command="{Binding SetNormalModeCommand}"/>
                <MenuItem Header="{DynamicResource Menu.Compact}"
                          IsCheckable="True"
                          IsChecked="{Binding IsCompactMode, Mode=OneWay}"
                          Command="{Binding SetCompactModeCommand}"/>
                <MenuItem Header="{DynamicResource Menu.Mini}"
                          IsCheckable="True"
                          IsChecked="{Binding IsMiniMode, Mode=OneWay}"
                          Command="{Binding SetMiniModeCommand}"/>
            </MenuItem>
            <Separator/>
            <MenuItem Header="{DynamicResource Menu.Settings}" Command="{Binding OpenSettingsCommand}"/>
            <MenuItem Header="{DynamicResource Menu.About}" Command="{Binding OpenAboutCommand}"/>
            <Separator/>
            <MenuItem Header="{DynamicResource Menu.Exit}" Command="{Binding ExitCommand}"/>
        </ContextMenu>
    </Window.ContextMenu>

    <Window.Resources>
        <DataTemplate x:Key="FullTemplate">
            <views:NormalView/>
        </DataTemplate>
        <DataTemplate x:Key="CompactTemplate">
            <views:CompactView/>
        </DataTemplate>
        <DataTemplate x:Key="MiniTemplate">
            <views:MiniView/>
        </DataTemplate>
    </Window.Resources>

    <ContentControl Content="{Binding}"
                    MouseDoubleClick="ContentControl_MouseDoubleClick">
        <ContentControl.Style>
            <Style TargetType="ContentControl">
                <Setter Property="ContentTemplate" Value="{StaticResource FullTemplate}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DisplayMode}" Value="Compact">
                        <Setter Property="ContentTemplate" Value="{StaticResource CompactTemplate}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding DisplayMode}" Value="Mini">
                        <Setter Property="ContentTemplate" Value="{StaticResource MiniTemplate}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ContentControl.Style>
    </ContentControl>
</Window>
