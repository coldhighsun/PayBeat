<Window x:Class="PayBeat.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PayBeat.App.Views.Controls"
        Title="{DynamicResource Settings.WindowTitle}"
        Width="400"
        Height="580"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        FontFamily="Segoe UI"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        PreviewMouseDown="Window_PreviewMouseDown">

    <Window.Resources>

        <!-- Tab item style -->
        <Style x:Key="SettingsTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border"
                                Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource BlueBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TabControl style -->
        <Style x:Key="SettingsTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <DockPanel>
                            <!-- Tab strip -->
                            <Border DockPanel.Dock="Top"
                                    BorderBrush="{DynamicResource SurfaceBrush}"
                                    BorderThickness="0,0,0,1">
                                <TabPanel IsItemsHost="True"
                                          Background="Transparent"
                                          HorizontalAlignment="Left" />
                            </Border>
                            <!-- Tab content -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Margin="0,20,0,0">
                                <ContentPresenter ContentSource="SelectedContent" />
                            </ScrollViewer>
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header used to group related settings within a tab -->
        <Style x:Key="SettingsSectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource BlueBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <!-- Display mode preview tooltip -->
        <Style x:Key="PreviewToolTip" TargetType="ToolTip">
            <Setter Property="Padding" Value="0" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource OverlayBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="6">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bubble popup shown next to a TextBox when its bound value fails validation -->
        <ControlTemplate x:Key="ValidationBubbleTemplate">
            <StackPanel>
                <AdornedElementPlaceholder x:Name="Placeholder" />
                <Popup IsOpen="True"
                       PlacementTarget="{Binding ElementName=Placeholder}"
                       Placement="Top"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Background="{DynamicResource RedBrush}"
                            CornerRadius="6"
                            Padding="8,5"
                            Margin="0,0,0,4">
                        <TextBlock Text="{Binding ElementName=Placeholder, Path=AdornedElement.(Validation.Errors)[0].ErrorContent}"
                                   Foreground="{DynamicResource BaseBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   MaxWidth="240" />
                    </Border>
                </Popup>
            </StackPanel>
        </ControlTemplate>

        <!-- TextBox style applying the validation bubble and a red border while invalid -->
        <Style x:Key="ValidatedTextBox" TargetType="TextBox">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ValidationBubbleTemplate}" />
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource RedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BaseBrush}"
            CornerRadius="12"
            BorderBrush="{DynamicResource OverlayBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.5" BlurRadius="24" ShadowDepth="0" />
        </Border.Effect>

        <DockPanel Margin="28,20" LastChildFill="True">

            <!-- Title -->
            <TextBlock DockPanel.Dock="Top"
                   Text="{DynamicResource Settings.Title}"
                   Foreground="{DynamicResource TextBrush}"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,16" />

            <!-- Error -->
            <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource RedBrush}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   MinHeight="16" />

            <!-- Buttons -->
            <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
                <Button Content="{DynamicResource Settings.Cancel}"
                    Command="{Binding CancelCommand}"
                    Margin="0,0,10,0"
                    Padding="20,10"
                    Background="{DynamicResource SurfaceBrush}"
                    Foreground="{DynamicResource TextBrush}" />
                <Button Content="{DynamicResource Settings.Save}"
                    Command="{Binding SaveCommand}"
                    Padding="20,10"
                    Background="{DynamicResource BlueBrush}"
                    Foreground="{DynamicResource BaseBrush}"
                    FontWeight="SemiBold" />
            </StackPanel>

            <!-- Tab control -->
            <TabControl DockPanel.Dock="Top"
                    Style="{StaticResource SettingsTabControl}">

                <!-- ── Salary Calculation ── -->
                <TabItem Header="{DynamicResource Settings.Tab.Salary}" Style="{StaticResource SettingsTabItem}">
                    <StackPanel>

                        <!-- ── Group: Salary ── -->
                        <TextBlock Text="{DynamicResource Settings.Section.Salary}" Style="{StaticResource SettingsSectionHeader}" />

                        <!-- Daily Salary -->
                        <TextBlock Text="{DynamicResource Settings.DailySalary}"
                               Foreground="{DynamicResource SubtextBrush}"
                               FontSize="12"
                               Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                 Text="{Binding CurrencyText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource SurfaceBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource OverlayBrush}"
                                 BorderThickness="1"
                                 Padding="10,8" />
                            <TextBox x:Name="SalaryBox"
                                 Grid.Column="2"
                                 Style="{StaticResource ValidatedTextBox}"
                                 Text="{Binding DailySalaryText, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 TextAlignment="Right"
                                 Background="{DynamicResource SurfaceBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource OverlayBrush}"
                                 BorderThickness="1"
                                 Padding="10,8"
                                 MaxLength="11"
                                 PreviewTextInput="Salary_PreviewTextInput"
                                 DataObject.Pasting="Salary_Pasting" />
                        </Grid>

                        <!-- ── Group: Work Schedule ── -->
                        <TextBlock Text="{DynamicResource Settings.Section.Schedule}" Style="{StaticResource SettingsSectionHeader}" />

                        <!-- Work Hours -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                   Text="{DynamicResource Settings.WorkHours}"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <controls:TimePickerControl SelectedTime="{Binding WorkStart}" />
                                <TextBlock Text="–" Foreground="{DynamicResource MutedBrush}" FontSize="13" VerticalAlignment="Center" Margin="6,0" />
                                <controls:TimePickerControl SelectedTime="{Binding WorkEnd}" />
                            </StackPanel>
                        </Grid>

                        <!-- Lunch break -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                  Content="{DynamicResource Settings.LunchBreakEnabled}"
                                  IsChecked="{Binding LunchBreakEnabled}"
                                  Foreground="{DynamicResource TextBrush}"
                                  FontSize="13"
                                  Cursor="Hand"
                                  VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    IsEnabled="{Binding LunchBreakEnabled}">
                                <controls:TimePickerControl SelectedTime="{Binding LunchBreakStart}" />
                                <TextBlock Text="–" Foreground="{DynamicResource MutedBrush}" FontSize="13" VerticalAlignment="Center" Margin="6,0" />
                                <controls:TimePickerControl SelectedTime="{Binding LunchBreakEnd}" />
                            </StackPanel>
                        </Grid>

                        <!-- Weekend earning -->
                        <CheckBox Content="{DynamicResource Settings.WorkOnWeekends}"
                              IsChecked="{Binding WorkOnWeekends}"
                              Foreground="{DynamicResource TextBrush}"
                              FontSize="13"
                              Cursor="Hand"
                              Margin="0,0,0,16" />

                        <!-- ── Group: Refresh ── -->
                        <TextBlock Text="{DynamicResource Settings.Section.Refresh}" Style="{StaticResource SettingsSectionHeader}" />

                        <!-- Refresh Interval -->
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                   Text="{DynamicResource Settings.RefreshInterval}"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding RefreshInterval}"
                                       Foreground="{DynamicResource GreenBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="{DynamicResource Settings.Seconds}"
                                       Foreground="{DynamicResource GreenBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                        <Slider Minimum="1"
                            Maximum="60"
                            Value="{Binding RefreshInterval}"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Foreground="{DynamicResource BlueBrush}" />
                    </StackPanel>
                </TabItem>

                <!-- ── Notifications ── -->
                <TabItem Header="{DynamicResource Settings.Tab.Notifications}" Style="{StaticResource SettingsTabItem}">
                    <StackPanel>

                        <!-- End of day reminder -->
                        <CheckBox Content="{DynamicResource Settings.EnableEndOfDayReminder}"
                              IsChecked="{Binding EnableEndOfDayReminder}"
                              Foreground="{DynamicResource TextBrush}"
                              FontSize="13"
                              Cursor="Hand"
                              Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,16" IsEnabled="{Binding EnableEndOfDayReminder}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                   Text="{DynamicResource Settings.EndOfDayReminderMinutes}"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                            <TextBox Grid.Column="2"
                                 Style="{StaticResource ValidatedTextBox}"
                                 Text="{Binding EndOfDayReminderMinutesText, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 TextAlignment="Right"
                                 Background="{DynamicResource SurfaceBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource OverlayBrush}"
                                 BorderThickness="1"
                                 Padding="10,8"
                                 MaxLength="2"
                                 PreviewTextInput="Integer_PreviewTextInput"
                                 DataObject.Pasting="Integer_Pasting" />
                        </Grid>

                        <!-- Milestone notifications -->
                        <CheckBox Content="{DynamicResource Settings.EnableMilestoneNotifications}"
                              IsChecked="{Binding EnableMilestoneNotifications}"
                              Foreground="{DynamicResource TextBrush}"
                              FontSize="13"
                              Cursor="Hand"
                              Margin="0,0,0,8" />
                        <Grid IsEnabled="{Binding EnableMilestoneNotifications}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                   Text="{DynamicResource Settings.MilestoneAmount}"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                            <TextBox Grid.Column="2"
                                 Style="{StaticResource ValidatedTextBox}"
                                 Text="{Binding MilestoneAmountText, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 TextAlignment="Right"
                                 Background="{DynamicResource SurfaceBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource OverlayBrush}"
                                 BorderThickness="1"
                                 Padding="10,8"
                                 MaxLength="11"
                                 PreviewTextInput="Salary_PreviewTextInput"
                                 DataObject.Pasting="Salary_Pasting" />
                        </Grid>
                    </StackPanel>
                </TabItem>

                <!-- ── Display ── -->
                <TabItem Header="{DynamicResource Settings.Tab.Display}" Style="{StaticResource SettingsTabItem}">
                    <StackPanel>

                        <!-- Display mode -->
                        <TextBlock Text="{DynamicResource Settings.DisplayMode}"
                               Foreground="{DynamicResource SubtextBrush}"
                               FontSize="12"
                               Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <RadioButton Content="{DynamicResource Settings.Flex}"
                                     IsChecked="{Binding IsFlexMode}"
                                     Foreground="{DynamicResource TextBrush}"
                                     FontSize="13"
                                     Cursor="Hand"
                                     Margin="0,0,20,0"
                                     ToolTipService.ShowDuration="60000"
                                     ToolTipService.InitialShowDelay="200">
                                <RadioButton.ToolTip>
                                    <ToolTip Style="{StaticResource PreviewToolTip}">
                                        <Image Source="pack://application:,,,/Resources/Screenshots/flex.png" Width="600" Stretch="Uniform" UseLayoutRounding="True" RenderOptions.BitmapScalingMode="HighQuality" />
                                    </ToolTip>
                                </RadioButton.ToolTip>
                            </RadioButton>
                            <RadioButton Content="{DynamicResource Settings.Normal}"
                                     IsChecked="{Binding IsNormalMode}"
                                     Foreground="{DynamicResource TextBrush}"
                                     FontSize="13"
                                     Cursor="Hand"
                                     Margin="0,0,20,0"
                                     ToolTipService.ShowDuration="60000"
                                     ToolTipService.InitialShowDelay="200">
                                <RadioButton.ToolTip>
                                    <ToolTip Style="{StaticResource PreviewToolTip}">
                                        <Image Source="pack://application:,,,/Resources/Screenshots/normal.png" Stretch="Uniform" UseLayoutRounding="True" RenderOptions.BitmapScalingMode="HighQuality" />
                                    </ToolTip>
                                </RadioButton.ToolTip>
                            </RadioButton>
                            <RadioButton Content="{DynamicResource Settings.Mini}"
                                     IsChecked="{Binding IsMiniMode}"
                                     Foreground="{DynamicResource TextBrush}"
                                     FontSize="13"
                                     Cursor="Hand"
                                     Margin="0,0,20,0"
                                     ToolTipService.ShowDuration="60000"
                                     ToolTipService.InitialShowDelay="200">
                                <RadioButton.ToolTip>
                                    <ToolTip Style="{StaticResource PreviewToolTip}">
                                        <Image Source="pack://application:,,,/Resources/Screenshots/mini.png" UseLayoutRounding="True" RenderOptions.BitmapScalingMode="HighQuality" />
                                    </ToolTip>
                                </RadioButton.ToolTip>
                            </RadioButton>
                            <RadioButton Content="{DynamicResource Settings.None}"
                                     IsChecked="{Binding IsNoneMode}"
                                     Foreground="{DynamicResource TextBrush}"
                                     FontSize="13"
                                     Cursor="Hand" />
                        </StackPanel>

                        <!-- Opacity -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                   Text="{DynamicResource Settings.Opacity}"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                   Text="{Binding Opacity, StringFormat={}{0:P0}}"
                                   Foreground="{DynamicResource GreenBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        </Grid>
                        <Slider Minimum="0.1"
                            Maximum="1.0"
                            Value="{Binding Opacity}"
                            TickFrequency="0.05"
                            IsSnapToTickEnabled="True"
                            Foreground="{DynamicResource BlueBrush}"
                            Margin="0,0,0,16" />

                        <!-- Always on top -->
                        <CheckBox Content="{DynamicResource Settings.AlwaysOnTop}"
                              IsChecked="{Binding AlwaysOnTop}"
                              Foreground="{DynamicResource TextBrush}"
                              FontSize="13"
                              Cursor="Hand"
                              Margin="0,0,0,16" />

                        <!-- Theme -->
                        <TextBlock Text="{DynamicResource Settings.Theme}"
                               Foreground="{DynamicResource SubtextBrush}"
                               FontSize="12"
                               Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding AvailableThemes}"
                              SelectedValue="{Binding Theme}"
                              SelectedValuePath="Code"
                              Background="{DynamicResource SurfaceBrush}"
                              Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource OverlayBrush}"
                              BorderThickness="1"
                              Padding="10,8"
                              HorizontalContentAlignment="Left">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding Name}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Code}" Value="auto">
                                                        <Setter Property="Text" Value="{DynamicResource Settings.ThemeAuto}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Code}" Value="light">
                                                        <Setter Property="Text" Value="{DynamicResource Settings.ThemeLight}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Code}" Value="dark">
                                                        <Setter Property="Text" Value="{DynamicResource Settings.ThemeDark}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </TabItem>

                <!-- ── System ── -->
                <TabItem Header="{DynamicResource Settings.Tab.System}" Style="{StaticResource SettingsTabItem}">
                    <StackPanel>

                        <!-- Run at startup -->
                        <CheckBox Content="{DynamicResource Settings.RunAtStartup}"
                              IsChecked="{Binding RunAtStartup}"
                              Foreground="{DynamicResource TextBrush}"
                              FontSize="13"
                              Cursor="Hand"
                              Margin="0,0,0,16" />

                        <!-- Hotkey -->
                        <TextBlock Text="{DynamicResource Settings.Hotkey}"
                               Foreground="{DynamicResource SubtextBrush}"
                               FontSize="12"
                               Margin="0,0,0,6" />
                        <TextBox x:Name="HotkeyBox"
                             Text="{Binding HotkeyDisplayText, Mode=OneWay}"
                             IsReadOnly="True"
                             Background="{DynamicResource SurfaceBrush}"
                             Foreground="{DynamicResource TextBrush}"
                             BorderBrush="{DynamicResource OverlayBrush}"
                             BorderThickness="1"
                             Padding="10,8"
                             Cursor="IBeam"
                             PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                             GotFocus="HotkeyBox_GotFocus"
                             LostFocus="HotkeyBox_LostFocus" />
                        <TextBlock Text="{DynamicResource Settings.HotkeyHint}"
                               Foreground="{DynamicResource MutedBrush}"
                               FontSize="11"
                               Margin="0,4,0,16" />

                        <!-- Language -->
                        <TextBlock Text="{DynamicResource Settings.Language}"
                               Foreground="{DynamicResource SubtextBrush}"
                               FontSize="12"
                               Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                              SelectedValue="{Binding Language}"
                              SelectedValuePath="Code"
                              Background="{DynamicResource SurfaceBrush}"
                              Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource OverlayBrush}"
                              BorderThickness="1"
                              Padding="10,8"
                              HorizontalContentAlignment="Left"
                              Margin="0,0,0,16">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding Name}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Code}" Value="auto">
                                                        <Setter Property="Text" Value="{DynamicResource Settings.LanguageAuto}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </DockPanel>
    </Border>
</Window>