<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Context menu -->
    <sys:String x:Key="Menu.DisplayMode">Display Mode</sys:String>
    <sys:String x:Key="Menu.Normal">Normal</sys:String>
    <sys:String x:Key="Menu.Mini">Mini</sys:String>
    <sys:String x:Key="Menu.None">None</sys:String>
    <sys:String x:Key="Menu.Flex">Flex</sys:String>
    <sys:String x:Key="Menu.Settings">Settings</sys:String>
    <sys:String x:Key="Menu.About">About</sys:String>
    <sys:String x:Key="Menu.Exit">Exit</sys:String>

    <!-- Normal view labels -->
    <sys:String x:Key="View.WorkStart">Start </sys:String>
    <sys:String x:Key="View.WorkEnd">End </sys:String>
    <sys:String x:Key="View.DailySalary">Daily</sys:String>

    <!-- Flex view labels -->
    <sys:String x:Key="View.Elapsed">Elapsed</sys:String>
    <sys:String x:Key="View.Remaining">Remaining</sys:String>
    <sys:String x:Key="View.WorkWindow">Work Hours</sys:String>

    <!-- Settings window -->
    <sys:String x:Key="Settings.WindowTitle">PayBeat Settings</sys:String>
    <sys:String x:Key="Settings.Title">Settings</sys:String>
    <sys:String x:Key="Settings.Cancel">Cancel</sys:String>
    <sys:String x:Key="Settings.Save">Save</sys:String>

    <!-- Salary tab -->
    <sys:String x:Key="Settings.Tab.Salary">Salary</sys:String>
    <sys:String x:Key="Settings.Section.Salary">SALARY</sys:String>
    <sys:String x:Key="Settings.Section.Schedule">WORK SCHEDULE</sys:String>
    <sys:String x:Key="Settings.Section.Refresh">REFRESH</sys:String>
    <sys:String x:Key="Settings.DailySalary">Daily Salary</sys:String>
    <sys:String x:Key="Settings.WorkHours">Work Hours</sys:String>
    <sys:String x:Key="Settings.RefreshInterval">Refresh Interval</sys:String>
    <sys:String x:Key="Settings.Seconds"> s</sys:String>
    <sys:String x:Key="Settings.LunchBreakEnabled">Deduct Lunch Break</sys:String>
    <sys:String x:Key="Settings.LunchBreakStart">Break Start</sys:String>
    <sys:String x:Key="Settings.LunchBreakEnd">Break End</sys:String>
    <sys:String x:Key="Settings.WorkOnWeekends">Earn on Weekends</sys:String>

    <!-- Notifications tab -->
    <sys:String x:Key="Settings.Tab.Notifications">Notifications</sys:String>
    <sys:String x:Key="Settings.EnableEndOfDayReminder">End-of-Day Reminder</sys:String>
    <sys:String x:Key="Settings.EndOfDayReminderMinutes">Minutes Before Work End</sys:String>
    <sys:String x:Key="Settings.EnableMilestoneNotifications">Milestone Notifications</sys:String>
    <sys:String x:Key="Settings.MilestoneAmount">Notify Every</sys:String>

    <!-- Display tab -->
    <sys:String x:Key="Settings.Tab.Display">Display</sys:String>
    <sys:String x:Key="Settings.DisplayMode">Display Mode</sys:String>
    <sys:String x:Key="Settings.Normal">Normal</sys:String>
    <sys:String x:Key="Settings.Mini">Mini</sys:String>
    <sys:String x:Key="Settings.None">None</sys:String>
    <sys:String x:Key="Settings.Flex">Flex</sys:String>
    <sys:String x:Key="Settings.Opacity">Opacity</sys:String>
    <sys:String x:Key="Settings.AlwaysOnTop">Always on Top</sys:String>

    <!-- System tab -->
    <sys:String x:Key="Settings.Tab.System">System</sys:String>
    <sys:String x:Key="Settings.RunAtStartup">Run at Startup</sys:String>
    <sys:String x:Key="Settings.Language">Language</sys:String>
    <sys:String x:Key="Settings.LanguageAuto">Auto</sys:String>
    <sys:String x:Key="Settings.Theme">Theme</sys:String>
    <sys:String x:Key="Settings.ThemeAuto">Auto</sys:String>
    <sys:String x:Key="Settings.ThemeLight">Light</sys:String>
    <sys:String x:Key="Settings.ThemeDark">Dark</sys:String>
    <sys:String x:Key="Settings.Hotkey">Toggle Visibility Hotkey</sys:String>
    <sys:String x:Key="Settings.HotkeyHint">Click, then press a key combination</sys:String>
    <sys:String x:Key="Settings.HotkeyCapturing">Press a key combination...</sys:String>

    <!-- About window -->
    <sys:String x:Key="About.WindowTitle">About PayBeat</sys:String>
    <sys:String x:Key="About.Description">A lightweight floating widget that shows your real-time earnings as the workday ticks by.</sys:String>
    <sys:String x:Key="About.Author">Author</sys:String>
    <sys:String x:Key="About.License">License</sys:String>
    <sys:String x:Key="About.GitHub">GitHub</sys:String>
    <sys:String x:Key="About.Close">Close</sys:String>

    <!-- Validation errors -->
    <sys:String x:Key="Error.SalaryPositive">Daily salary must be greater than 0</sys:String>
    <sys:String x:Key="Error.SalaryTooLarge">Daily salary cannot exceed 99,999,999</sys:String>
    <sys:String x:Key="Error.WorkEndAfterStart">Work end must be later than work start</sys:String>
    <sys:String x:Key="Error.AlreadyRunning">PayBeat is already running.</sys:String>
    <sys:String x:Key="Error.HotkeyConflict">Failed to register hotkey {0}. It may already be in use by another application.</sys:String>
    <sys:String x:Key="Error.LunchBreakInvalid">Lunch break must fall within work hours and end after it starts</sys:String>
    <sys:String x:Key="Error.MilestoneAmountPositive">Milestone amount must be greater than 0</sys:String>
    <sys:String x:Key="Error.MilestoneAmountTooLarge">Milestone amount cannot exceed the daily salary</sys:String>
    <sys:String x:Key="Error.EndOfDayReminderMinutesInvalid">Reminder minutes must be an integer between 1 and 60</sys:String>

    <!-- Tray notifications -->
    <sys:String x:Key="Tray.HiddenTooltip">I love work!</sys:String>
    <sys:String x:Key="Notification.MilestoneTitle">Earnings Milestone</sys:String>
    <sys:String x:Key="Notification.MilestoneBody">You've earned {0} today!</sys:String>
    <sys:String x:Key="Notification.EndOfDayTitle">Almost Done</sys:String>
    <sys:String x:Key="Notification.EndOfDayBody">Work ends in {0} minutes.</sys:String>

</ResourceDictionary>
